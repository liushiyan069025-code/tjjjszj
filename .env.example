# ============================================================
# AI API 配置（在「诺神配置」页面填写，此处仅作示例参考）
# 默认使用阿里云百炼 DashScope，国内可直接访问，无需翻墙
# ============================================================

# 申通 LLM 网关示例（构建时可预设，用户只填 Token）
# VITE_DEFAULT_GATEWAY_URL=https://devops-llmgateway.sto.cn/compatible-mode/v1
# VITE_DEFAULT_MODEL=qwen-plus
# 申请地址：https://bailian.console.aliyun.com/ -> 模型广场 -> API-KEY 管理
# Base URL: https://dashscope.aliyuncs.com/compatible-mode
# 模型: qwen-vl-max（识图）/ qwen-plus（纯文本）
VITE_ANTHROPIC_API_KEY=your_dashscope_api_key_here

# 其他国内可用服务（无需翻墙）：
# DeepSeek  -> Base URL: https://api.deepseek.com        模型: deepseek-chat
# 智谱 GLM  -> Base URL: https://open.bigmodel.cn/api/paas/v4  模型: glm-4v（识图）/ glm-4-plus
